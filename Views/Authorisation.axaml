<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="DemoProject.Authorisation"
             MinWidth="800"
             MinHeight="450"
             CornerRadius="15">

    <UserControl.Styles>
        <Style Selector="Button.smooth-btn-light">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="25,15"/>
            <Setter Property="CornerRadius" Value="25"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Regular"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="btnBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}"
                            Cursor="Hand">
                        
                        <ContentPresenter Name="contentPresenter"
                                          Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Background="Transparent"
                                          Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.smooth-btn-light /template/ Border">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.3"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button.smooth-btn-light:pointerover /template/ Border">
            <Setter Property="Background" Value="#20FFFFFF"/>
        </Style>

        <Style Selector="Button.smooth-btn-light:pressed /template/ Border">
            <Setter Property="Background" Value="#40FFFFFF"/>
        </Style>

        <Style Selector="Button.smooth-btn-dark">
            <Setter Property="Background" Value="#669E85"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="25,15"/>
            <Setter Property="CornerRadius" Value="25"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Regular"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="btnBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}"
                            Cursor="Hand">
                        
                        <ContentPresenter Name="contentPresenter"
                                          Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Background="Transparent"
                                          Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.smooth-btn-dark /template/ Border">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.3"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button.smooth-btn-dark:pointerover /template/ Border">
            <Setter Property="Background" Value="#52806b"/>
        </Style>

        <Style Selector="Button.smooth-btn-dark:pressed /template/ Border">
            <Setter Property="Background" Value="#436052"/>
        </Style>

        <Style Selector="Button.underline-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#669E85"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid>
                        <ContentPresenter Name="PART_ContentPresenter"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Content="{TemplateBinding Content}"/>
                        <Border Height="2" Background="#0078D7" VerticalAlignment="Bottom"
                                HorizontalAlignment="Center" RenderTransformOrigin="0.5, 0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="0"/>
                            </Border.RenderTransform>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.underline-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#669E85"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid>
                        <ContentPresenter Name="PART_ContentPresenter"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Content="{TemplateBinding Content}"/>
                        <Border Name="underline" 
                                Height="2" 
                                Width="0"
                                Background="#669E85" 
                                VerticalAlignment="Bottom"
                                HorizontalAlignment="Center"/>
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.underline-btn /template/ Border#underline">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Width" Duration="0:0:0.3"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button.underline-btn:pointerover /template/ Border#underline">
            <Setter Property="Width" Value="140"/>
        </Style>
        
        <Style Selector="TextBox.styled-input">
            <Setter Property="Background" Value="#f8f8f6"/>
            <Setter Property="BorderBrush" Value="#DFE6E9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="15,11"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="#2D3436"/>
        </Style>
        
        <Style Selector="TextBox.styled-input /template/ Border#PART_BorderElement">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.25"/>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.25"/>
                </Transitions>
            </Setter>
        </Style>
        
        <Style Selector="TextBox.styled-input:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="BorderBrush" Value="#B2BEC3"/>
        </Style>
        
        <Style Selector="TextBox.styled-input:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#669E85"/>
        </Style>

    </UserControl.Styles>

    <Grid ColumnDefinitions="*, 300" Background="White">
        <Grid Grid.Column="0">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                <Label FontSize="25" Foreground="#669E85" Content="Войти в аккаунт" Margin="0,0,0,20"
                       FontWeight="Bold" HorizontalContentAlignment="Center" Padding="0"/>
                <TextBox Classes="styled-input" PlaceholderText="Email" Width="300"/>
                <TextBox Classes="styled-input" PlaceholderText="Пароль" Width="300"/>
                <Button Classes="underline-btn" Content="Узнать подробнее" HorizontalAlignment="Center" Width="200"/>
                <Button Classes="smooth-btn-dark" Content="Вход" HorizontalAlignment="Center"
                        Width="220" Margin="20"/>
            </StackPanel>
        </Grid>
        <Grid Grid.Column="1">
            <Grid.Background>
                <ImageBrush Source="avares://DemoProject/Assets/Image/background_auth.jpg"
                            Stretch="UniformToFill"/>
            </Grid.Background>
            
            <StackPanel VerticalAlignment="Top" HorizontalAlignment="Right" Margin="15" Orientation="Horizontal">
                <Image Width="50" Height="50" Source="avares://DemoProject/Assets/Image/icon.png" Margin="0,0,5,0"/>
                <Label Content="Security" VerticalContentAlignment="Center" FontSize="15" FontWeight="Bold" Foreground="White"/>
            </StackPanel>
            
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                <Label FontSize="25" Foreground="White" Content="Привет, друг!" Margin="0,0,0,20"
                       FontWeight="Bold" HorizontalContentAlignment="Center" Padding="0"/>
                <TextBlock FontSize="16" Foreground="White" Text="Если ты не зарегестрирован, то не стесняйся и начинай путешействие с нами"
                       FontWeight="Light" Padding="0" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,25"/>
                <Button Click="ToRegistration" Classes="smooth-btn-light" Content="Регистрация" HorizontalAlignment="Center" Width="220"/>
            </StackPanel>
        </Grid>
    </Grid>

</UserControl>
